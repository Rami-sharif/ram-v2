# ============================================================
# RAM v2 — Phase 1 environment template
# Copy to .env and fill in real values. .env is gitignored.
# Do NOT commit real keys. Leave this file with empty values.
# ============================================================

# ---- AI / external APIs (you provide) ----
# API key for Google Gemini, used by the agent to reason over alerts and by
# the semantic memory pipeline (via google-genai) to generate embeddings.
GEMINI_API_KEY=
# Which Gemini model the investigation agent calls for tool-use/reasoning.
GEMINI_MODEL=gemini-2.5-flash
# API key for VirusTotal, used by the agent's enrichment tool to look up
# reputation data for IPs observed in alerts.
VIRUSTOTAL_API_KEY=

# ---- TheHive (API key generated after first boot, then pasted here) ----
# Base URL the agent-service uses to reach TheHive's REST API inside the
# docker network (service name "thehive", internal port 9000).
THEHIVE_URL=http://thehive:9000/thehive
# TheHive API key used for authenticated case-creation calls; case creation
# only activates once this is populated (see thehive_enabled in config.py).
THEHIVE_API_KEY=
# TheHive organisation the agent-service operates cases/alerts under.
THEHIVE_ORGANISATION=ram-v2
# Admin account (default password is rotated by scripts/bootstrap; values land in .env)
# Email/login of TheHive's initial admin user, created on first boot.
THEHIVE_ADMIN_USER=admin@thehive.local
# Password for the TheHive admin account above; generated by the bootstrap script.
THEHIVE_ADMIN_PASSWORD=

# ---- PostgreSQL + pgvector (unused in Phase 1, provisioned for later) ----
# Username for the pgvector-enabled Postgres instance (semantic memory store).
POSTGRES_USER=ramv2
# Password for the Postgres user above.
POSTGRES_PASSWORD=
# Database name created/used inside the Postgres container.
POSTGRES_DB=ramv2

# ---- Agent service ----
# Log verbosity for the agent-service application (e.g. INFO, DEBUG).
AGENT_LOG_LEVEL=INFO
# Maximum number of tool-use/reasoning iterations the agent loop can take
# before it must stop and return a result, to bound cost/latency.
AGENT_MAX_ITERATIONS=8

# ---- Read-only Wazuh Indexer user for investigation tools (created by
#      scripts/bootstrap-indexer-rouser.sh; password lands in .env) ----
# Username of the read-only OpenSearch/Wazuh Indexer account the agent's
# investigation tools use to query alert/log data (least-privilege access).
WAZUH_INDEXER_RO_USER=ram_agent_ro
# Password for the read-only Wazuh Indexer account above.
WAZUH_INDEXER_RO_PASSWORD=

# ---- Operator token for /memory inspect/edit/delete endpoints (M2M only) ----
# Shared secret required to call the agent-service's operator-only memory
# management endpoints (inspect/edit/delete); machine-to-machine auth, not
# used by the analyst console.
OPERATOR_API_TOKEN=

# ---- Analyst console (session auth) ----
# Secret key used to sign/encrypt the analyst console's session cookies.
SESSION_SECRET_KEY=
# Public-facing TheHive URL used to build case deep-links shown to analysts
# in the console (may differ from the internal THEHIVE_URL).
CONSOLE_THEHIVE_PUBLIC_URL=http://localhost:9000/thehive

# ---- Triage router (severity_score is on the 0-100 scale) ----
# Score threshold below which an alert is triaged as "low" severity.
TRIAGE_MEDIUM_THRESHOLD=40
# Score threshold at/above which an alert is triaged as "high" severity
# (escalated/flagged); scores between the medium and high thresholds are "medium".
TRIAGE_HIGH_THRESHOLD=80
# Time window (hours) used to deduplicate repeated/similar alerts so the
# same incident doesn't spawn duplicate cases.
TRIAGE_DEDUP_WINDOW_HOURS=6
# Whether "low" severity alerts still get a (pre-resolved) case created in
# TheHive, or are only recorded to memory/logs without a case.
TRIAGE_LOW_CREATE_RESOLVED_CASE=false
